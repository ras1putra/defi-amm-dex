# API configuration
API_ID=defi-amm-dex-api
API_PORT=8081
API_ENV=development

# Clickhouse database configuration
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=defi_amm_dex
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Web3 / RPC configuration
NODE_RPC_URL=http://localhost:8545
CHAIN_RPC_URL=http://localhost:8545
CHAIN_ID=31337
CHAIN_NAME=Hardhat
EXPLORER_URL=http://localhost:5100

# Contract Addresses
CONTRACT_V2_AMM=0xYourV2AMMAddress
CONTRACT_V2_ROUTER=0xYourV2RouterAddress
CONTRACT_WETH=0xYourWETHAddress
CONTRACT_STAKING=0xYourStakingRewardsAddress
STABLECOIN_ADDRESS=0xYourMockUSDCAddress

# Indexer & API settings
INDEXER_SYNC_INTERVAL=3
INDEXER_BATCH_SIZE=100
ALLOWED_ORIGINS=http://localhost:3000

# S3 compatible storage configuration
S3_ENDPOINT=http://localhost:3900
S3_REGION=garage
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=defi-dex-tokens
S3_PUBLIC_URL=http://defi-dex-tokens.web.localhost:3902
S3_ADMIN_ENDPOINT=http://localhost:3903
